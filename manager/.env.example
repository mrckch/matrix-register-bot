# Beispiel-Konfiguration fuer den Matrix Bot Manager Container.
# In ein .env-File neben dem Compose-File ablegen und mit `docker compose --env-file ...`
# oder per `env_file:` ins Compose ziehen.

# Synapse-URL aus Container-Sicht. Im Docker-Netz typischerweise der Service-Name.
SYNAPSE_URL=http://matrix-synapse:8008

# Admin-Access-Token eines Server-Admins. NIE committen.
SYNAPSE_ADMIN_TOKEN=syt_change_me

# Optional — default 8080
# PORT=8080
