# Beispiel-Output des Assistenten — so sieht die generierte Credentials-Datei aus.
# Die ECHTE Datei liegt unter ~/.config/matrix-register-bot/<botname>.env
# und wird mit chmod 600 abgelegt. Diese Beispieldatei hier enthaelt nur
# Platzhalter und darf committed werden.

HOMESERVER_URL="https://matrix.example.org"
BOT_USER_ID="@wetterbot:example.org"
BOT_LOCALPART="wetterbot"
BOT_DISPLAYNAME="Wetter Bot"
BOT_PASSWORD="REPLACE_ME_RANDOM_PASSWORD"
BOT_ACCESS_TOKEN="syt_REPLACE_ME_TOKEN"
BOT_DEVICE_ID="matrix-register-bot"
